{
  "version": 2,
  "redirects": [
    { "source": "/", "destination": "/app-debug.apk", "permanent": true }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    }
  ],
  "experimentalServices": {
    "web": {
      "routePrefix": "/",
      "framework": "vite",
      "buildCommand": "npm run build"
    }
  }
}
