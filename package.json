{
  "name": "rest-express",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "NODE_ENV=development tsx server/index.ts",
    "build": "tsx script/build.ts",
    "start": "NODE_ENV=production node server/railway-start.cjs",
    "check": "tsc",
    "db:push": "drizzle-kit push",
    "android:sync": "npx cap sync android",
    "android:open": "npx cap open android",
    "android:apk": "npm run build && npx cap sync android && cd android && ./gradlew assembleDebug",
    "android:prod": "echo \"VITE_API_BASE_URL=https://komsukomsu.online\" > client/.env.production && npm run build && npx cap sync android && npx cap run android",
    "android:prod:target": "echo \"VITE_API_BASE_URL=https://komsukomsu.online\" > client/.env.production && npm run build && npx cap sync android && npx cap run android --target $ANDROID_TARGET",
    "android:usb:local": "adb reverse tcp:5050 tcp:5050 && echo \"VITE_API_BASE_URL=http://localhost:5050\" > client/.env.production && npm run build && npx cap sync android && npx cap run android",
    "android:wifi:local": "HOST_IP=$(ipconfig getifaddr en0 || ipconfig getifaddr en1) && echo \"VITE_API_BASE_URL=http://$HOST_IP:5050\" > client/.env.production && npm run build && npx cap sync android && npx cap run android",
    "android:wifi:local:target": "HOST_IP=$(ipconfig getifaddr en0 || ipconfig getifaddr en1) && echo \"VITE_API_BASE_URL=http://$HOST_IP:5050\" > client/.env.production && npm run build && npx cap sync android && npx cap run android --target $ANDROID_TARGET"
  },
