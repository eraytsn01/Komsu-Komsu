{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks",
    "buildCommand": "npm run build"
  },
  "deploy": {
    "startCommand": "NODE_ENV=production node server/railway-start.cjs",
    "restartPolicyType": "on_failure",
    "restartPolicyMaxRetries": 5
  }
}
